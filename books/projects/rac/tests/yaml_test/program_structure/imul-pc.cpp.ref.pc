
typedef sc_uint<32> ui32;
typedef sc_uint<64> ui64;
typedef sc_uint<35> ui35;
typedef sc_uint<3> ui3;
typedef sc_uint<33> ui33;
typedef sc_uint<67> ui67;


ui3 Encode(sc_uint<3> slice) {
  sc_uint<3> enc;
  switch (slice) {
  case 4:
    enc = 6;
    break;
  case 5:
  case 6:
    enc = 5;
    break;
  case 7:
  case 0:
    enc = 0;
    break;
  case 1:
  case 2:
    enc = 1;
    break;
  case 3:
    enc = 2;
    break;
  default:
    assert(0);
  }
  return enc;
}

ui3[17] Booth(sc_uint<35> x) {
  sc_uint<35> x35 = x << 1;
  ui3 a[17];
  for (int k = 0; k < 17; k++) {
    a[k] = Encode(x35[2 * k + 2:2 * k]);
  }
  return a;
}

ui33[17] PartialProducts(ui3 m21[17], sc_uint<33> y) {
  ui33 pp[17];
  for (int k = 0; k < 17; k++) {
    sc_uint<33> row;
    switch (m21[k][1:0]) {
    case 2:
      row = y << 1;
      break;
    case 1:
      row = y;
      break;
    default:
      row = 0;
    }
    pp[k] = m21[k][2] ? ~row : row;
  }
  return pp;
}

ui64[17] Align(ui3 bds[17], ui33 pps[17]) {
  bool sb[17];
  bool psb[18];
  for (int k = 0; k < 17; k++) {
    sb[k] = bds[k][2];
    psb[k + 1] = bds[k][2];
  }
  ui64 tble[17];
  for (int k = 0; k < 17; k++) {
    sc_uint<67> tmp = 0;
    tmp set_slc pps[k];
    if (k == 0) {
      tmp[33] = sb[k];
      tmp[34] = sb[k];
      tmp[35] = !sb[k];
    }
    else  {
      tmp[2 * k - 2] = psb[k];
      tmp[2 * k + 33] = !sb[k];
      tmp[2 * k + 34] = 1;
    }
    tble[k] = tmp;
  }
  return tble;
}

<ui64, ui64> Compress32(sc_uint<64> in0, sc_uint<64> in1, sc_uint<64> in2) {
  sc_uint<64> out0 = in0 ^ in1 ^ in2;
  sc_uint<64> out1 = in0 & in1 | in0 & in2 | in1 & in2;
  out1 <<= 1;
  return <out0out1>;
}

<ui64, ui64> Compress42(sc_uint<64> in0, sc_uint<64> in1, sc_uint<64> in2, sc_uint<64> in3) {
  sc_uint<64> temp = (in1 & in2 | in1 & in3 | in2 & in3) << 1;
  sc_uint<64> out0 = in0 ^ in1 ^ in2 ^ in3 ^ temp;
  sc_uint<64> out1 = (in0 & ~(in0 ^ in1 ^ in2 ^ in3)) | (temp & (in0 ^ in1 ^ in2 ^ in3));
  out1 <<= 1;
  return <out0out1>;
}

ui64 Sum(ui64 in[17]) {
  ui64 A1[8];
  for (uint i = 0; i < 4; i++) {
    <A1[2 * i + 0], A1[2 * i + 0], A1[2 * i + 1]> = Compress42(in[4 * i], in[4 * i + 1], in[4 * i + 2], in[4 * i + 3]);
  }
  ui64 A2[4];
  for (uint i = 0; i < 2; i++) {
    <A2[2 * i + 0], A2[2 * i + 0], A2[2 * i + 1]> = Compress42(A1[4 * i], A1[4 * i + 1], A1[4 * i + 2], A1[4 * i + 3]);
  }
  ui64 A3[2];
  <A3[0], A3[0], A3[1]> = Compress42(A2[0], A2[1], A2[2], A2[3]);
  ui64 A4[2];
  <A4[0], A4[0], A4[1]> = Compress32(A3[0], A3[1], in[16]);
  return A4[0] + A4[1];
}

ui64 Imul(sc_uint<32> s1, sc_uint<32> s2) {
  ui3 bd[17] = Booth(s1);
  ui33 pp[17] = PartialProducts(bd, s2);
  ui64 tble[17] = Align(bd, pp);
  sc_uint<64> prod = Sum(tble);
  return prod;
}

<bool, ui64, ui64> ImulTest(sc_uint<32> s1, sc_uint<32> s2) {
  sc_uint<64> spec_result = s1 * s2;
  sc_uint<64> imul_result = Imul(s1, s2);
  return <spec_result == imul_resultspec_resultimul_result>;
}

