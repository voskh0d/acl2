Grammar

    0 $accept: program $end

    1 program: program program_element
    2        | program_element

    3 program_element: type_dec ';'
    4                | const_dec ';'
    5                | func_def
    6                | multiple_const_dec ';'

    7 type_dec: typedef_dec
    8         | STRUCT ID struct_type
    9         | ENUM ID enum_type

   10 typedef_dec: TYPEDEF typedef_type ID
   11            | typedef_dec '[' arithmetic_expression ']'

   12 typedef_type: primitive_type
   13             | register_type
   14             | array_param_type
   15             | mv_type
   16             | TYPEID

   17 type_spec: typedef_type
   18          | STRUCT struct_type
   19          | ENUM enum_type

   20 primitive_type: INT
   21               | UINT
   22               | INT64
   23               | UINT64
   24               | BOOL

   25 register_type: AC_FIXED
   26              | AC_INT '<' arithmetic_expression ',' boolean '>'

   27 array_param_type: ARRAY '<' type_spec ',' arithmetic_expression '>'

   28 struct_type: '{' struct_field_list '}'

   29 struct_field_list: struct_field
   30                  | struct_field_list struct_field

   31 struct_field: type_spec ID ';'

   32 enum_type: '{' enum_const_dec_list '}'

   33 enum_const_dec_list: enum_const_dec
   34                    | enum_const_dec_list ',' enum_const_dec

   35 enum_const_dec: ID
   36               | ID '=' expression

   37 mv_type: TUPLE '<' type_spec mv_type_rest

   38 mv_type_rest: '>'
   39             | ',' type_spec mv_type_rest

   40 primary_expression: constant
   41                   | symbol_ref
   42                   | funcall
   43                   | '(' expression ')'

   44 constant: integer
   45         | boolean

   46 integer: NAT
   47        | '-' NAT

   48 boolean: TRUE
   49        | FALSE

   50 symbol_ref: ID

   51 funcall: ID '(' expr_list ')'
   52        | TEMPLATEID '<' arith_expr_list '>' '(' arith_expr_list ')'

   53 postfix_expression: primary_expression
   54                   | array_or_bit_ref
   55                   | struct_ref
   56                   | subrange

   57 array_or_bit_ref: postfix_expression '[' expression ']'

   58 struct_ref: postfix_expression '.' ID

   59 subrange: postfix_expression '.' SLC '<' NAT '>' '(' expression ')'

   60 prefix_expression: postfix_expression
   61                  | unary_op prefix_expression
   62                  | '(' type_spec ')' prefix_expression
   63                  | type_spec '(' expression ')'

   64 unary_op: '+'
   65         | '-'
   66         | '~'
   67         | '!'

   68 mult_expression: prefix_expression
   69                | mult_expression '*' prefix_expression
   70                | mult_expression '/' prefix_expression
   71                | mult_expression '%' prefix_expression

   72 add_expression: mult_expression
   73               | add_expression '+' mult_expression
   74               | add_expression '-' mult_expression

   75 arithmetic_expression: add_expression
   76                      | arithmetic_expression LSHFT_OP add_expression
   77                      | arithmetic_expression RSHFT_OP add_expression

   78 rel_expression: arithmetic_expression
   79               | rel_expression '<' arithmetic_expression
   80               | rel_expression '>' arithmetic_expression
   81               | rel_expression LE_OP arithmetic_expression
   82               | rel_expression GE_OP arithmetic_expression

   83 eq_expression: rel_expression
   84              | eq_expression EQ_OP rel_expression
   85              | eq_expression NE_OP rel_expression

   86 and_expression: eq_expression
   87               | and_expression '&' eq_expression

   88 xor_expression: and_expression
   89               | xor_expression '^' and_expression

   90 ior_expression: xor_expression
   91               | ior_expression '|' xor_expression

   92 log_and_expression: ior_expression
   93                   | log_and_expression AND_OP ior_expression

   94 log_or_expression: log_and_expression
   95                  | log_or_expression OR_OP log_and_expression

   96 cond_expression: log_or_expression
   97                | log_or_expression '?' expression ':' cond_expression

   98 mv_expression: mv_type '(' expr_list ')'

   99 expression: cond_expression
  100           | mv_expression

  101 expr_list: %empty
  102          | nontrivial_expr_list

  103 nontrivial_expr_list: expression
  104                     | nontrivial_expr_list ',' expression

  105 arith_expr_list: %empty
  106                | nontrivial_arith_expr_list

  107 nontrivial_arith_expr_list: arithmetic_expression
  108                           | nontrivial_arith_expr_list ',' arithmetic_expression

  109 statement: simple_statement ';'
  110          | block
  111          | for_statement
  112          | if_statement
  113          | switch_statement

  114 r_statement: final_statement
  115            | r_block

  116 simple_statement: var_dec
  117                 | const_dec
  118                 | multiple_var_dec
  119                 | multiple_const_dec
  120                 | break_statement
  121                 | assignment
  122                 | multiple_assignment
  123                 | assertion
  124                 | null_statement

  125 var_dec: type_spec untyped_var_dec

  126 untyped_var_dec: ID
  127                | ID '=' expression
  128                | ID '=' array_or_struct_init
  129                | ID '[' arithmetic_expression ']'
  130                | ID '[' arithmetic_expression ']' '=' array_or_struct_init

  131 array_or_struct_init: '{' init_list '}'
  132                     | '{' '}'

  133 init_list: expression
  134          | init_list ',' expression

  135 const_dec: CONST type_spec untyped_const_dec

  136 untyped_const_dec: ID '=' expression
  137                  | ID '=' array_or_struct_init
  138                  | ID '[' arithmetic_expression ']' '=' array_or_struct_init

  139 multiple_var_dec: var_dec ',' untyped_var_dec
  140                 | multiple_var_dec ',' untyped_var_dec

  141 multiple_const_dec: const_dec ',' untyped_const_dec
  142                   | multiple_const_dec ',' untyped_const_dec

  143 break_statement: BREAK

  144 return_statement: RETURN
  145                 | RETURN expression

  146 assignment: expression assign_op expression
  147           | expression inc_op
  148           | postfix_expression '.' SET_SLC '(' expression ',' expression ')'

  149 assign_op: '='
  150          | RSHFT_ASSIGN
  151          | LSHFT_ASSIGN
  152          | ADD_ASSIGN
  153          | SUB_ASSIGN
  154          | MUL_ASSIGN
  155          | DIV_ASSIGN
  156          | MOD_ASSIGN
  157          | AND_ASSIGN
  158          | XOR_ASSIGN
  159          | OR_ASSIGN

  160 inc_op: INC_OP
  161       | DEC_OP

  162 multiple_assignment: TIE '(' nontrivial_expr_list ')' '=' postfix_expression

  163 assertion: ASSERT '(' expression ')'

  164 null_statement: %empty

  165 dummy: %empty

  166 block: '{' dummy statement_list '}'

  167 r_block: '{' dummy r_statement_list '}'

  168 statement_list: %empty
  169               | statement_list statement

  170 r_statement_list: statement_list final_statement

  171 $@1: %empty

  172 for_statement: FOR $@1 '(' for_init ';' expression ';' assignment ')' statement

  173 for_init: var_dec
  174         | assignment

  175 if_statement: IF '(' expression ')' statement ELSE statement
  176             | IF '(' expression ')' statement

  177 switch_statement: SWITCH '(' expression ')' '{' case_list '}'

  178 case_list: case
  179          | case_list case

  180 case: CASE case_label ':' statement_list
  181     | DEFAULT ':' statement_list

  182 case_label: constant
  183           | symbol_ref

  184 final_statement: return_statement ';'
  185                | IF '(' expression ')' r_statement ELSE r_statement

  186 $@2: %empty

  187 func_def: type_spec ID $@2 '(' param_dec_list ')' '{' r_statement_list '}'
  188         | func_template

  189 param_dec_list: %empty
  190               | nontrivial_param_dec_list

  191 nontrivial_param_dec_list: var_dec
  192                          | nontrivial_param_dec_list ',' var_dec

  193 $@3: %empty

  194 func_template: TEMPLATE $@3 '<' template_param_dec_list '>' type_spec ID '(' param_dec_list ')' r_block

  195 template_param_dec_list: %empty
  196                        | nontrivial_template_param_dec_list

  197 nontrivial_template_param_dec_list: template_param_dec
  198                                   | nontrivial_template_param_dec_list ',' template_param_dec

  199 template_param_dec: type_spec ID


