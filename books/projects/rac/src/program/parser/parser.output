Grammar

    0 $accept: program $end

    1 program: program program_element
    2        | program_element

    3 program_element: type_dec ';'
    4                | const_dec ';'
    5                | func_def

    6 type_dec: typedef_dec
    7         | STRUCT ID struct_type
    8         | ENUM ID enum_type

    9 typedef_dec: TYPEDEF typedef_type ID
   10            | typedef_dec '[' arithmetic_expression ']'

   11 typedef_type: primitive_type
   12             | register_type
   13             | array_param_type
   14             | mv_type
   15             | TYPEID

   16 type_spec: typedef_type
   17          | STRUCT struct_type
   18          | ENUM enum_type

   19 primitive_type: INT
   20               | UINT
   21               | INT64
   22               | UINT64
   23               | BOOL

   24 register_type: AC_FIXED
   25              | AC_INT '<' arithmetic_expression ',' boolean '>'

   26 array_param_type: ARRAY '<' type_spec ',' arithmetic_expression '>'

   27 struct_type: '{' struct_field_list '}'

   28 struct_field_list: struct_field
   29                  | struct_field_list struct_field

   30 struct_field: type_spec ID ';'

   31 enum_type: '{' enum_const_dec_list '}'

   32 enum_const_dec_list: enum_const_dec
   33                    | enum_const_dec_list ',' enum_const_dec

   34 enum_const_dec: ID
   35               | ID '=' expression

   36 mv_type: TUPLE '<' type_spec mv_type_rest

   37 mv_type_rest: '>'
   38             | ',' type_spec mv_type_rest

   39 primary_expression: constant
   40                   | symbol_ref
   41                   | funcall
   42                   | '(' expression ')'

   43 constant: integer
   44         | boolean

   45 integer: NAT
   46        | '-' NAT

   47 boolean: TRUE
   48        | FALSE

   49 symbol_ref: ID

   50 funcall: ID '(' expr_list ')'
   51        | TEMPLATEID '<' arith_expr_list '>' '(' arith_expr_list ')'

   52 postfix_expression: primary_expression
   53                   | array_or_bit_ref
   54                   | struct_ref
   55                   | subrange

   56 array_or_bit_ref: postfix_expression '[' expression ']'

   57 struct_ref: postfix_expression '.' ID

   58 subrange: postfix_expression '.' SLC '<' NAT '>' '(' expression ')'

   59 prefix_expression: postfix_expression
   60                  | unary_op prefix_expression
   61                  | '(' type_spec ')' prefix_expression
   62                  | type_spec '(' expression ')'

   63 unary_op: '+'
   64         | '-'
   65         | '~'
   66         | '!'

   67 mult_expression: prefix_expression
   68                | mult_expression '*' prefix_expression
   69                | mult_expression '/' prefix_expression
   70                | mult_expression '%' prefix_expression

   71 add_expression: mult_expression
   72               | add_expression '+' mult_expression
   73               | add_expression '-' mult_expression

   74 arithmetic_expression: add_expression
   75                      | arithmetic_expression LSHFT_OP add_expression
   76                      | arithmetic_expression RSHFT_OP add_expression

   77 rel_expression: arithmetic_expression
   78               | rel_expression '<' arithmetic_expression
   79               | rel_expression '>' arithmetic_expression
   80               | rel_expression LE_OP arithmetic_expression
   81               | rel_expression GE_OP arithmetic_expression

   82 eq_expression: rel_expression
   83              | eq_expression EQ_OP rel_expression
   84              | eq_expression NE_OP rel_expression

   85 and_expression: eq_expression
   86               | and_expression '&' eq_expression

   87 xor_expression: and_expression
   88               | xor_expression '^' and_expression

   89 ior_expression: xor_expression
   90               | ior_expression '|' xor_expression

   91 log_and_expression: ior_expression
   92                   | log_and_expression AND_OP ior_expression

   93 log_or_expression: log_and_expression
   94                  | log_or_expression OR_OP log_and_expression

   95 cond_expression: log_or_expression
   96                | log_or_expression '?' expression ':' cond_expression

   97 mv_expression: mv_type '(' expr_list ')'

   98 expression: cond_expression
   99           | mv_expression

  100 expr_list: %empty
  101          | nontrivial_expr_list

  102 nontrivial_expr_list: expression
  103                     | nontrivial_expr_list ',' expression

  104 arith_expr_list: %empty
  105                | nontrivial_arith_expr_list

  106 nontrivial_arith_expr_list: arithmetic_expression
  107                           | nontrivial_arith_expr_list ',' arithmetic_expression

  108 statement: simple_statement ';'
  109          | block
  110          | for_statement
  111          | if_statement
  112          | switch_statement

  113 r_statement: final_statement
  114            | r_block

  115 simple_statement: var_dec
  116                 | const_dec
  117                 | multiple_var_dec
  118                 | multiple_const_dec
  119                 | break_statement
  120                 | assignment
  121                 | multiple_assignment
  122                 | assertion
  123                 | null_statement

  124 var_dec: type_spec untyped_var_dec

  125 untyped_var_dec: ID
  126                | ID '=' expression
  127                | ID '=' array_or_struct_init
  128                | ID '[' arithmetic_expression ']'
  129                | ID '[' arithmetic_expression ']' '=' array_or_struct_init

  130 array_or_struct_init: '{' init_list '}'
  131                     | '{' '}'

  132 init_list: expression
  133          | init_list ',' expression

  134 const_dec: CONST type_spec untyped_const_dec

  135 untyped_const_dec: ID '=' expression
  136                  | ID '=' array_or_struct_init
  137                  | ID '[' arithmetic_expression ']' '=' array_or_struct_init

  138 multiple_var_dec: var_dec ',' untyped_var_dec
  139                 | multiple_var_dec ',' untyped_var_dec

  140 multiple_const_dec: const_dec ',' untyped_const_dec
  141                   | multiple_const_dec ',' untyped_const_dec

  142 break_statement: BREAK

  143 return_statement: RETURN
  144                 | RETURN expression

  145 assignment: expression assign_op expression
  146           | expression inc_op
  147           | postfix_expression '.' SET_SLC '(' expression ',' expression ')'

  148 assign_op: '='
  149          | RSHFT_ASSIGN
  150          | LSHFT_ASSIGN
  151          | ADD_ASSIGN
  152          | SUB_ASSIGN
  153          | MUL_ASSIGN
  154          | DIV_ASSIGN
  155          | MOD_ASSIGN
  156          | AND_ASSIGN
  157          | XOR_ASSIGN
  158          | OR_ASSIGN

  159 inc_op: INC_OP
  160       | DEC_OP

  161 multiple_assignment: TIE '(' nontrivial_expr_list ')' '=' postfix_expression

  162 assertion: ASSERT '(' expression ')'

  163 null_statement: %empty

  164 dummy: %empty

  165 block: '{' dummy statement_list '}'

  166 r_block: '{' dummy r_statement_list '}'

  167 statement_list: %empty
  168               | statement_list statement

  169 r_statement_list: statement_list final_statement

  170 $@1: %empty

  171 for_statement: FOR $@1 '(' for_init ';' expression ';' assignment ')' statement

  172 for_init: var_dec
  173         | assignment

  174 if_statement: IF '(' expression ')' statement ELSE statement
  175             | IF '(' expression ')' statement

  176 switch_statement: SWITCH '(' expression ')' '{' case_list '}'

  177 case_list: case
  178          | case_list case

  179 case: CASE case_label ':' statement_list
  180     | DEFAULT ':' statement_list

  181 case_label: constant
  182           | symbol_ref

  183 final_statement: return_statement ';'
  184                | IF '(' expression ')' r_statement ELSE r_statement

  185 $@2: %empty

  186 func_def: type_spec ID $@2 '(' param_dec_list ')' '{' r_statement_list '}'
  187         | func_template

  188 param_dec_list: %empty
  189               | nontrivial_param_dec_list

  190 nontrivial_param_dec_list: var_dec
  191                          | nontrivial_param_dec_list ',' var_dec

  192 $@3: %empty

  193 func_template: TEMPLATE $@3 '<' template_param_dec_list '>' type_spec ID '(' param_dec_list ')' r_block

  194 template_param_dec_list: %empty
  195                        | nontrivial_template_param_dec_list

  196 nontrivial_template_param_dec_list: template_param_dec
  197                                   | nontrivial_template_param_dec_list ',' template_param_dec

  198 template_param_dec: type_spec ID


